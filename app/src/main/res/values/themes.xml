<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.Festabook" parent="Theme.Material3.DayNight.NoActionBar">
        <!--기존 color scale은 유지되었기 때문에 부득이하게 하드코딩 하게 되었습니다.
        만약 기존의 color.xml도 새로운 테마에 맞게 수정한다면 이에 맞춰서 수정하겠습니다.  -->
        <item name="android:windowBackground">#FAFAFA</item>
        <item name="SkeletonBackground">@color/gray300</item>
        <item name="android:windowContentTransitions">true</item>
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.Festabook.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/gray050</item>
    </style>

    <style name="Theme.Festabook" parent="Base.Theme.Festabook" />
</resources>
